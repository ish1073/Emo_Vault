<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
   version="3.1">

    <display-name>EmoVault</display-name>

    <!-- Servlet Definitions -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.emovault.servlet.LoginServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.emovault.servlet.RegisterServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>com.emovault.servlet.DashboardServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>EmotionServlet</servlet-name>
        <servlet-class>com.emovault.servlet.EmotionServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>DiaryServlet</servlet-name>
        <servlet-class>com.emovault.servlet.DiaryServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>HabitServlet</servlet-name>
        <servlet-class>com.emovault.servlet.HabitServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>RegretServlet</servlet-name>
        <servlet-class>com.emovault.servlet.RegretServlet</servlet-class>
    </servlet>


    <servlet>
        <servlet-name>ExpertServlet</servlet-name>
        <servlet-class>com.emovault.servlet.ExpertServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>TimeCapsuleServlet</servlet-name>
        <servlet-class>com.emovault.servlet.TimeCapsuleServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>BehaviorAnalyzerServlet</servlet-name>
        <servlet-class>com.emovault.servlet.BehaviorAnalyzerServlet</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>AnalyticsServlet</servlet-name>
        <servlet-class>com.emovault.servlet.AnalyticsServlet</servlet-class>
    </servlet>

    <!-- Servlet Mappings -->
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>EmotionServlet</servlet-name>
        <url-pattern>/emotion</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>DiaryServlet</servlet-name>
        <url-pattern>/diary</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>HabitServlet</servlet-name>
        <url-pattern>/habit</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>RegretServlet</servlet-name>
        <url-pattern>/regret</url-pattern>
    </servlet-mapping>


    <servlet-mapping>
        <servlet-name>ExpertServlet</servlet-name>
        <url-pattern>/expert</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>TimeCapsuleServlet</servlet-name>
        <url-pattern>/timecapsule</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>BehaviorAnalyzerServlet</servlet-name>
        <url-pattern>/behavior_analyzer</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>AnalyticsServlet</servlet-name>
        <url-pattern>/analytics</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

</web-app>
